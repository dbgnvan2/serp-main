          2
        ]
      },
      {
        "type": "list",
        "list": [
          {
            "snippet": "Registered Clinical Counsellors (RCC): $130\u2013$180 per session (50 mins)."
          },
          {
            "snippet": "Registered Psychologists: $200\u2013$250+ per session."
          },
          {
            "snippet": "Couples/Family Therapy: $155\u2013$250 for 50\u201375 minute sessions."
          },
          {
            "snippet": "Reduced Cost/Interns: $30\u2013$125 per hour (sliding scale)."
          }
        ],
        "reference_indexes": [
