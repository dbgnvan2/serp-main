      {
        "type": "paragraph",
        "snippet": "Counselling in Vancouver typically costs between $130 and $250+ per 50-minute session for a Registered Clinical Counsellor (RCC) or Registered Psychologist. Rates vary based on the provider's experience, with intern/student therapists offering lower rates of $40\u2013$90. Couples/family counselling is generally higher, ranging from $175 to $325+ per session.",
        "reference_indexes": [
          0,
          1,
          2
        ]
      },
      {
        "type": "paragraph",
        "snippet": "Typical Costs in Vancouver (per 50-60 min session):"
      },
      {
        "type": "list",
        "list": [
          {
            "snippet": "Registered Clinical Counsellor (RCC): $130\u2013$180"
          },
          {
            "snippet": "Registered Psychologist: $200\u2013$250"
          },
          {
            "snippet": "Intern/Student Therapist: $40\u2013$90"
          },
          {
            "snippet": "Couples/Family Therapy: $175\u2013$325"
          }
        ],
        "reference_indexes": [
          0,
          2,
          1
        ]
      },
      {
        "type": "paragraph",
        "snippet": "Lower-Cost and Specialized Options:"
      },
      {
        "type": "list",
        "list": [
          {
            "snippet": "Reduced-Cost/Sliding Scale: Many clinics offer reduced rates based on income."
          },
          {
            "snippet": "Non-Profit Agencies: Organizations like the Adler Centre ($65-$90 for interns) or CMHA North/West Vancouver ($35-$70) provide low-cost options.",
            "snippet_links": [
              {
                "text": "CMHA North/West Vancouver",
                "link": "https://willowtreecounselling.ca/wp-content/uploads/resources/reduced-cost-counselling.pdf"
              }
            ]
          },
          {
            "snippet": "ICBC/Victim Services: ICBC-covered trauma therapy is free for eligible individuals."
          },
          {
            "snippet": "Free Options: 8-1-1 or 2-1-1 can connect you with local, free, or low-cost services.",
            "snippet_links": [
              {
                "text": "8-1-1 or 2-1-1",
                "link": "https://helpstartshere.gov.bc.ca/blog/free-or-low-cost-services-bc"
              }
            ]
          }
        ],
        "reference_indexes": [
          0,
          4,
          6,
          3,
          8
        ]
      },
      {
        "type": "paragraph",
        "snippet": "Important Notes:"
      },
      {
        "type": "list",
        "list": [
          {
            "snippet": "Insurance: Most, but not all, extended health plans cover Registered Clinical Counsellors or Psychologists; check your plan."
          },
          {
            "snippet": "No MSP: Standard, private, or non-profit counselling is generally not covered by MSP."
          },
          {
            "snippet": "Wait Times: Low-cost options may have wait times of 6 months or more."
          },
          {
            "snippet": "Fees: Many therapists accept debit, credit, or e-transfers, often collecting payment at the end of the session."
          }
        ],
        "reference_indexes": [
          1,
          5,
          7
        ]
      }
