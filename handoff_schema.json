{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompetitorHandoff",
  "description": "Validated handoff from serp-discover (Tool 1) to serp-compete (Tool 2)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_run_id",
    "source_run_timestamp",
    "client_domain",
    "client_brand_names",
    "targets",
    "exclusions"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "source_run_id": {
      "type": "string"
    },
    "source_run_timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "client_domain": {
      "type": "string"
    },
    "client_brand_names": {
      "type": "array",
      "items": { "type": "string" }
    },
    "targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "url",
          "domain",
          "rank",
          "entity_type",
          "content_type",
          "title",
          "source_keyword",
          "primary_keyword_for_url"
        ],
        "properties": {
          "url":                    { "type": "string" },
          "domain":                 { "type": "string" },
          "rank":                   { "type": "integer" },
          "entity_type":            { "type": "string" },
          "content_type":           { "type": "string" },
          "title":                  { "type": "string" },
          "source_keyword":         { "type": "string" },
          "primary_keyword_for_url": { "type": "string" }
        }
      }
    },
    "exclusions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "client_urls_excluded",
        "omit_list_excluded",
        "omit_list_used"
      ],
      "properties": {
        "client_urls_excluded": { "type": "integer" },
        "omit_list_excluded":   { "type": "integer" },
        "omit_list_used": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
